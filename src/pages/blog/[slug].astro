---
import BaseLayout from "../../layouts/BaseLayout.astro";
import SiteHeader from "../../components/SiteHeader.astro";
import SiteFooter from "../../components/SiteFooter.astro";
import { getCollection, render } from "astro:content";
import { site } from "../../data/site";

export async function getStaticPaths() {
  const posts = await getCollection("blog");
  return posts
    .filter((post) => !post.data.draft)
    .map((post) => ({
      params: { slug: post.id },
      props: { post },
    }));
}

const { post } = Astro.props;
const { Content } = await render(post);

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "long",
    day: "numeric",
  });
}
---

<BaseLayout title={`${post.data.title} — ${site.name}`} description={post.data.description}>
  <SiteHeader current="blog" />
  <main id="main" class="blog-main">
    <article class="post-article">
      <div class="wrap">
        <p class="section-label">
          <a href="/blog">← Blog</a>
        </p>
        <header class="post-header">
          <time datetime={post.data.pubDate.toISOString()}>{formatDate(post.data.pubDate)}</time>
          <h1 class="section-title">{post.data.title}</h1>
          <p class="section-lead">{post.data.description}</p>
          <ul class="post-tags">
            {
              post.data.tags.map((tag) => (
                <li>
                  <span class="skill-tag">{tag}</span>
                </li>
              ))
            }
          </ul>
        </header>
      </div>

      {
        post.data.heroImage && (
          <figure class="post-hero">
            <img
              src={post.data.heroImage}
              alt={post.data.heroAlt ?? ""}
              width="1400"
              height="788"
              loading="eager"
              fetchpriority="high"
            />
            {post.data.heroCredit && (
              <figcaption>
                Photo by{" "}
                {post.data.heroCreditUrl ? (
                  <a href={post.data.heroCreditUrl} target="_blank" rel="noopener noreferrer">
                    {post.data.heroCredit}
                  </a>
                ) : (
                  post.data.heroCredit
                )}{" "}
                on{" "}
                <a
                  href="https://unsplash.com/?utm_source=dane_cameron_portfolio&utm_medium=referral"
                  target="_blank"
                  rel="noopener noreferrer"
                >
                  Unsplash
                </a>
              </figcaption>
            )}
          </figure>
        )
      }

      <div class="wrap prose">
        <Content />
      </div>
    </article>
  </main>
  <SiteFooter />
</BaseLayout>
