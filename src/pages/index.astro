---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import SiteFooter from "../components/SiteFooter.astro";
import { getCollection } from "astro:content";
import {
  site,
  competencies,
  experience,
  education,
  projects,
  freelance,
} from "../data/site";

const latestPosts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf());

function formatDate(date: Date) {
  return date.toLocaleDateString("en-US", {
    year: "numeric",
    month: "short",
    day: "numeric",
  });
}
---

<BaseLayout>
  <SiteHeader current="home" />

  <main id="main">
    <section class="hero wrap" id="top" aria-label="Introduction">
      <div class="hero-content">
        <p class="hero-kicker">{site.location}</p>
        <h1 class="hero-name">{site.name}</h1>
        <p class="hero-title">{site.title} · {site.tagline}</p>
        <p class="hero-lead">{site.summary}</p>
        <div class="cta-row">
          <a class="btn btn-primary" href={site.links.github} target="_blank" rel="noopener noreferrer"
            >GitHub</a
          >
          <a class="btn btn-ghost" href={site.links.linkedin} target="_blank" rel="noopener noreferrer"
            >LinkedIn</a
          >
          <a class="btn btn-ghost" href={site.links.email}>Email</a>
        </div>
        <div class="meta-bar">
          <span>Open to full-time & part-time</span>
          <span>{site.location}</span>
          <a href={site.phoneHref}>{site.phone}</a>
          <a href={site.links.email}>{site.links.emailLabel}</a>
        </div>
      </div>
      <div class="hero-portrait">
        <img
          class="hero-photo"
          src={site.portrait}
          alt={site.portraitAlt}
          width="640"
          height="640"
          fetchpriority="high"
        />
      </div>
    </section>

    <section id="about">
      <div class="wrap">
        <p class="section-label">About</p>
        <h2 class="section-title">Full-stack C#, React & SQL for product teams</h2>
        <div class="about-text">
          {site.about.map((paragraph) => <p>{paragraph}</p>)}
        </div>
      </div>
    </section>

    <section id="domains">
      <div class="wrap">
        <p class="section-label">Focus</p>
        <h2 class="section-title">Healthcare, fintech & ecommerce</h2>
        <p class="section-lead">
          Customer-facing web apps and APIs where performance, data integrity, and trust matter  - 
          from B2C ecommerce patterns to regulated healthcare and fintech workflows.
        </p>
        <div class="domains-grid">
          {
            site.domains.map((domain) => (
              <article class="domain">
                <div class="domain-media">
                  <img
                    src={domain.image}
                    alt={domain.imageAlt}
                    width="1200"
                    height="800"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <h3>{domain.title}</h3>
                <p>{domain.body}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="skills">
      <div class="wrap">
        <p class="section-label">Core competencies</p>
        <h2 class="section-title">Tech stack & focus areas</h2>
        <p class="section-lead">
          C#, React, Next.js, and SQL Server at the core - plus Angular, Python/Django, Azure/AWS,
          Redis, Kafka, AppSec, and AI-assisted delivery for healthcare, fintech, and ecommerce teams.
        </p>
        <div class="skills-grid">
          {
            competencies.map((item) => (
              <article class="skill">
                <h3>{item.title}</h3>
                <ul class="skill-tags">
                  {item.items.map((skill) => (
                    <li>
                      <span class="skill-tag">{skill}</span>
                    </li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="experience">
      <div class="wrap">
        <p class="section-label">Experience</p>
        <h2 class="section-title">12 years shipping customer-facing web software</h2>
        <p class="section-lead">
          From Auth0 (Bellevue) through Checkr and HashiCorp (San Francisco) to Cloudrise (Grand
          Junction) - full-stack delivery with strong data and cloud fundamentals.
        </p>
        <div class="timeline">
          {
            experience.map((job) => (
              <article class="job">
                <div class="job-header">
                  <div>
                    <h3 class="job-role">{job.role}</h3>
                    <p class="job-company">
                      {job.company}
                      {job.location ? ` · ${job.location}` : ""}
                    </p>
                  </div>
                  <p class="job-dates">{job.dates}</p>
                </div>
                <ul>
                  {job.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="projects">
      <div class="wrap">
        <p class="section-label">Selected work</p>
        <h2 class="section-title">Projects on GitHub</h2>
        <p class="section-lead">
          B2C-style React products with APIs, SQL, RBAC, and payments - patterns that map to
          ecommerce, healthcare, and fintech SaaS. More on{" "}
          <a href={site.links.github} target="_blank" rel="noopener noreferrer">github.com/dcam25</a>.
        </p>
        <div class="projects-grid">
          {
            projects.map((project) => (
              <a
                class="project"
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <div class="project-media">
                  <img
                    src={project.image}
                    alt={project.imageAlt}
                    width="1200"
                    height="800"
                    loading="lazy"
                    decoding="async"
                  />
                </div>
                <div class="project-body">
                  <h3>{project.name}</h3>
                  <p>{project.description}</p>
                  <ul class="project-tags">
                    {project.tags.map((tag) => (
                      <li>
                        <span class="skill-tag">{tag}</span>
                      </li>
                    ))}
                  </ul>
                  <span class="project-link">View repo →</span>
                </div>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section id="blog">
      <div class="wrap">
        <div class="home-blog-head">
          <div>
            <p class="section-label">Writing</p>
            <h2 class="section-title">Latest from the blog</h2>
            <p class="section-lead home-blog-lead">
              Practical notes on full-stack delivery, CI/CD, auth, and AI guardrails.{" "}
              <a href="/blog/">Browse all posts</a>.
            </p>
          </div>
          <div class="blog-carousel-controls" aria-hidden="false">
            <button type="button" class="blog-carousel-btn" data-blog-prev aria-label="Previous posts">
              ←
            </button>
            <button type="button" class="blog-carousel-btn" data-blog-next aria-label="Next posts">
              →
            </button>
          </div>
        </div>

        <div class="blog-carousel" data-blog-carousel>
          <div class="blog-carousel-track" data-blog-track tabindex="0" aria-label="Blog posts carousel">
            {
              latestPosts.map((post) => (
                <a class="home-blog-card" href={`/blog/${post.id}/`}>
                  {post.data.heroImage && (
                    <div class="home-blog-media">
                      <img
                        src={post.data.heroImage}
                        alt=""
                        width="640"
                        height="360"
                        loading="lazy"
                        decoding="async"
                      />
                    </div>
                  )}
                  <div class="home-blog-body">
                    <time datetime={post.data.pubDate.toISOString()}>
                      {formatDate(post.data.pubDate)}
                    </time>
                    <h3>{post.data.title}</h3>
                    <p>{post.data.description}</p>
                    <span class="project-link">Read post →</span>
                  </div>
                </a>
              ))
            }
          </div>
          <div class="blog-carousel-progress" data-blog-progress role="tablist" aria-label="Carousel progress"></div>
        </div>
      </div>
    </section>

    <script>
      const root = document.querySelector("[data-blog-carousel]");
      const track = document.querySelector<HTMLElement>("[data-blog-track]");
      const prev = document.querySelector<HTMLButtonElement>("[data-blog-prev]");
      const next = document.querySelector<HTMLButtonElement>("[data-blog-next]");
      const progressWrap = document.querySelector<HTMLElement>("[data-blog-progress]");

      if (root && track && prev && next && progressWrap) {
        const cards = Array.from(track.querySelectorAll<HTMLElement>(".home-blog-card"));
        const DURATION = 6500;
        const SLIDE_MS = 780;
        let index = 0;
        let raf = 0;
        let slideRaf = 0;
        let startedAt = 0;
        let elapsed = 0;
        let playing = false;
        let hoverPaused = false;
        let sliding = false;
        const reduceMotion = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

        const easeOutCubic = (t: number) => 1 - Math.pow(1 - t, 3);
        const easeInOutCubic = (t: number) =>
          t < 0.5 ? 4 * t * t * t : 1 - Math.pow(-2 * t + 2, 3) / 2;

        const pageSize = () => {
          const width = track.clientWidth;
          if (width < 640) return 1;
          if (width < 980) return 2;
          return 3;
        };

        const maxIndex = () => Math.max(0, cards.length - pageSize());
        const canAutoplay = () => !reduceMotion && cards.length > pageSize();

        const segments = () =>
          Array.from(progressWrap.querySelectorAll<HTMLButtonElement>(".blog-carousel-seg"));

        const setSegmentProgress = (i: number, value: number) => {
          const fill = segments()[i]?.querySelector<HTMLElement>(".blog-carousel-seg-fill");
          if (fill) {
            fill.style.transform = `translateY(-50%) scaleX(${Math.max(0, Math.min(1, value))})`;
          }
        };

        const syncProgress = (activeProgress = 0) => {
          segments().forEach((seg, i) => {
            const complete = i < index;
            const active = i === index;
            seg.classList.toggle("is-complete", complete);
            seg.classList.toggle("is-active", active);
            seg.setAttribute("aria-current", active ? "true" : "false");
            if (complete) setSegmentProgress(i, 1);
            else if (active) setSegmentProgress(i, activeProgress);
            else setSegmentProgress(i, 0);
          });
        };

        const rebuildProgress = () => {
          progressWrap.innerHTML = "";
          const pages = maxIndex() + 1;
          for (let i = 0; i < pages; i++) {
            const seg = document.createElement("button");
            seg.type = "button";
            seg.className = "blog-carousel-seg";
            seg.setAttribute("aria-label", `Go to blog slide ${i + 1}`);
            seg.innerHTML = '<span class="blog-carousel-seg-fill" aria-hidden="true"></span>';
            seg.addEventListener("click", () => {
              seg.blur();
              goTo(i, true);
            });
            progressWrap.appendChild(seg);
          }
        };

        const stop = () => {
          playing = false;
          if (raf) cancelAnimationFrame(raf);
          raf = 0;
          if (startedAt) {
            elapsed += performance.now() - startedAt;
            startedAt = 0;
          }
        };

        const animateScrollTo = (targetLeft: number) =>
          new Promise<void>((resolve) => {
            if (reduceMotion) {
              track.scrollLeft = targetLeft;
              resolve();
              return;
            }
            if (slideRaf) cancelAnimationFrame(slideRaf);
            const from = track.scrollLeft;
            const delta = targetLeft - from;
            if (Math.abs(delta) < 1) {
              resolve();
              return;
            }
            sliding = true;
            root.classList.add("is-sliding");
            track.classList.add("is-animating");
            const start = performance.now();

            const frame = (now: number) => {
              const t = Math.min(1, (now - start) / SLIDE_MS);
              track.scrollLeft = from + delta * easeInOutCubic(t);
              if (t < 1) {
                slideRaf = requestAnimationFrame(frame);
              } else {
                sliding = false;
                slideRaf = 0;
                track.classList.remove("is-animating");
                root.classList.remove("is-sliding");
                resolve();
              }
            };
            slideRaf = requestAnimationFrame(frame);
          });

        const advance = () => {
          if (index >= maxIndex()) goTo(0, true);
          else goTo(index + 1, true);
        };

        const tick = (now: number) => {
          if (!playing) return;
          const raw = Math.min(1, (elapsed + (now - startedAt)) / DURATION);
          // Ease the visible fill so the bar doesn't feel linear/harsh
          const eased = easeOutCubic(raw);
          syncProgress(eased);
          if (raw >= 1) {
            elapsed = 0;
            startedAt = 0;
            advance();
            return;
          }
          raf = requestAnimationFrame(tick);
        };

        const start = (force = false) => {
          if ((!force && hoverPaused) || !canAutoplay()) {
            if (!playing) syncProgress(Math.min(1, elapsed / DURATION || 0));
            return;
          }
          stop();
          playing = true;
          startedAt = performance.now();
          raf = requestAnimationFrame(tick);
        };

        const goTo = async (nextIndex: number, restartTimer = false) => {
          const max = maxIndex();
          index = ((nextIndex % (max + 1)) + (max + 1)) % (max + 1);
          const card = cards[index];
          if (!card) return;
          const target = card.offsetLeft - track.offsetLeft;
          if (restartTimer) {
            stop();
            elapsed = 0;
            syncProgress(0);
          } else {
            syncProgress(0);
          }
          await animateScrollTo(target);
          if (restartTimer) start(true);
        };

        const step = (dir: number) => {
          if (sliding) return;
          goTo(index + dir, true);
        };

        prev.addEventListener("click", () => {
          (document.activeElement as HTMLElement | null)?.blur?.();
          step(-1);
        });
        next.addEventListener("click", () => {
          (document.activeElement as HTMLElement | null)?.blur?.();
          step(1);
        });

        track.addEventListener("keydown", (event) => {
          if (event.key === "ArrowLeft") {
            event.preventDefault();
            step(-1);
          }
          if (event.key === "ArrowRight") {
            event.preventDefault();
            step(1);
          }
        });

        let scrollTick = 0;
        track.addEventListener(
          "scroll",
          () => {
            if (sliding) return;
            window.clearTimeout(scrollTick);
            scrollTick = window.setTimeout(() => {
              const left = track.scrollLeft;
              let closest = 0;
              let best = Number.POSITIVE_INFINITY;
              cards.forEach((card, i) => {
                const dist = Math.abs(card.offsetLeft - track.offsetLeft - left);
                if (dist < best) {
                  best = dist;
                  closest = i;
                }
              });
              const nextIndex = Math.min(closest, maxIndex());
              if (nextIndex !== index) {
                index = nextIndex;
                elapsed = 0;
                if (playing) startedAt = performance.now();
                syncProgress(0);
              }
            }, 80);
          },
          { passive: true },
        );

        root.addEventListener("mouseenter", () => {
          hoverPaused = true;
          stop();
        });
        root.addEventListener("mouseleave", () => {
          hoverPaused = false;
          start();
        });

        window.addEventListener("resize", () => {
          stop();
          if (slideRaf) cancelAnimationFrame(slideRaf);
          sliding = false;
          track.classList.remove("is-animating");
          root.classList.remove("is-sliding");
          rebuildProgress();
          index = Math.min(index, maxIndex());
          goTo(index, false);
          if (!hoverPaused) start();
        });

        rebuildProgress();
        goTo(0, false);
        start();
      }
    </script>

    <section id="education">
      <div class="wrap">
        <p class="section-label">Education</p>
        <h2 class="section-title">Computer Science</h2>
        <div class="edu-list">
          {
            education.map((item) => (
              <article class="edu-item">
                <h3>{item.degree}</h3>
                <p>
                  {item.school}
                  {item.location ? ` · ${item.location}` : ""} · {item.dates}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="freelance" id="hire">
      <div class="wrap">
        <p class="section-label">Contact Me</p>
        <h2 class="section-title">{freelance.headline}</h2>
        <p class="section-lead">{freelance.body}</p>
        <div class="contact-row">
          <a class="btn btn-primary" href={site.links.email}>{site.links.emailLabel}</a>
          <a class="btn btn-ghost" href={site.links.linkedin} target="_blank" rel="noopener noreferrer"
            >LinkedIn</a
          >
          <a class="btn btn-ghost" href={site.links.guru} target="_blank" rel="noopener noreferrer"
            >Guru</a
          >
          <a class="btn btn-ghost" href={site.links.github} target="_blank" rel="noopener noreferrer"
            >GitHub</a
          >
          <a class="btn btn-ghost" href={site.phoneHref}>{site.phone}</a>
        </div>
      </div>
    </section>
  </main>

  <SiteFooter />
</BaseLayout>
