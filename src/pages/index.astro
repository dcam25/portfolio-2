---
import BaseLayout from "../layouts/BaseLayout.astro";
import {
  site,
  competencies,
  experience,
  education,
  projects,
  freelance,
} from "../data/site";
---

<BaseLayout>
  <header class="site-header" id="site-header">
    <div class="wrap nav">
      <a class="nav-brand" href="#top">{site.name}</a>
      <ul class="nav-links">
        <li><a href="#about">About</a></li>
        <li><a href="#skills">Skills</a></li>
        <li><a href="#experience">Experience</a></li>
        <li><a href="#projects">Projects</a></li>
        <li><a href="#education">Education</a></li>
        <li><a href="#hire">Hire</a></li>
      </ul>
    </div>
  </header>

  <main id="main">
    <section class="hero wrap" id="top" aria-label="Introduction">
      <div class="hero-content">
        <p class="hero-kicker">{site.location}</p>
        <h1 class="hero-name">{site.name}</h1>
        <p class="hero-title">{site.title} · {site.tagline}</p>
        <p class="hero-lead">{site.summary}</p>
        <div class="cta-row">
          <a class="btn btn-primary" href={site.links.github} target="_blank" rel="noopener noreferrer"
            >GitHub</a
          >
          <a class="btn btn-ghost" href={site.links.guru} target="_blank" rel="noopener noreferrer"
            >Hire on Guru</a
          >
          <a class="btn btn-ghost" href={site.links.email}>Email</a>
        </div>
        <div class="meta-bar">
          <span>{site.location}</span>
          <a href={site.phoneHref}>{site.phone}</a>
          <a href={site.links.github} target="_blank" rel="noopener noreferrer">github.com/dcam25</a>
        </div>
      </div>
      <div class="hero-portrait">
        <img
          class="hero-photo"
          src={site.portrait}
          alt={site.portraitAlt}
          width="640"
          height="640"
          fetchpriority="high"
        />
      </div>
    </section>

    <section id="about">
      <div class="wrap">
        <p class="section-label">About</p>
        <h2 class="section-title">Platform engineering that ships securely</h2>
        <div class="about-text">
          <p>
            I partner with application teams to onboard repositories, standardize workflows, and
            create paved-road tooling in Python, TypeScript, GitHub Actions, Pulumi, Docker, AWS, and
            JFrog Artifactory.
          </p>
          <p>
            Experienced in regulated environments (SOC2, NIST) with audit-ready change control,
            security scanning, and operational runbooks. MS + BS in Computer Science.
          </p>
        </div>
      </div>
    </section>

    <section id="skills">
      <div class="wrap">
        <p class="section-label">Core competencies</p>
        <h2 class="section-title">Tech stack & focus areas</h2>
        <p class="section-lead">
          Developer platforms, secure pipelines, and cloud infrastructure built for teams that need
          to move fast without cutting corners.
        </p>
        <div class="skills-grid">
          {
            competencies.map((item) => (
              <article class="skill">
                <h3>{item.title}</h3>
                <p>{item.items}</p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="experience">
      <div class="wrap">
        <p class="section-label">Experience</p>
        <h2 class="section-title">12 years shipping infrastructure & platforms</h2>
        <p class="section-lead">
          From Auth0 through HashiCorp and Cloudrise — building CI/CD, cloud foundations, and
          developer experience.
        </p>
        <div class="timeline">
          {
            experience.map((job) => (
              <article class="job">
                <div class="job-header">
                  <div>
                    <h3 class="job-role">{job.role}</h3>
                    <p class="job-company">{job.company}</p>
                  </div>
                  <p class="job-dates">{job.dates}</p>
                </div>
                <ul>
                  {job.bullets.map((bullet) => (
                    <li>{bullet}</li>
                  ))}
                </ul>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section id="projects">
      <div class="wrap">
        <p class="section-label">Selected work</p>
        <h2 class="section-title">Projects on GitHub</h2>
        <p class="section-lead">
          A few public builds — platforms, AI interfaces, and infrastructure docs.
          More on{" "}
          <a href={site.links.github} target="_blank" rel="noopener noreferrer">github.com/dcam25</a>.
        </p>
        <div class="projects-grid">
          {
            projects.map((project) => (
              <a
                class="project"
                href={project.url}
                target="_blank"
                rel="noopener noreferrer"
              >
                <h3>{project.name}</h3>
                <p>{project.description}</p>
                <span class="project-link">View repo →</span>
              </a>
            ))
          }
        </div>
      </div>
    </section>

    <section id="education">
      <div class="wrap">
        <p class="section-label">Education</p>
        <h2 class="section-title">Computer Science</h2>
        <div class="edu-list">
          {
            education.map((item) => (
              <article class="edu-item">
                <h3>{item.degree}</h3>
                <p>
                  {item.school} · {item.dates}
                </p>
              </article>
            ))
          }
        </div>
      </div>
    </section>

    <section class="freelance" id="hire">
      <div class="wrap">
        <p class="section-label">Freelance</p>
        <h2 class="section-title">{freelance.headline}</h2>
        <p class="section-lead">{freelance.body}</p>
        <div class="contact-row">
          <a class="btn btn-primary" href={site.links.guru} target="_blank" rel="noopener noreferrer"
            >View Guru profile</a
          >
          <a class="btn btn-ghost" href={site.links.github} target="_blank" rel="noopener noreferrer"
            >GitHub</a
          >
          <a class="btn btn-ghost" href={site.phoneHref}>{site.phone}</a>
        </div>
      </div>
    </section>
  </main>

  <footer class="site-footer">
    <div class="wrap footer-inner">
      <p>© {new Date().getFullYear()} {site.name}</p>
      <div class="footer-links">
        <a href={site.links.github} target="_blank" rel="noopener noreferrer">GitHub</a>
        <a href={site.links.guru} target="_blank" rel="noopener noreferrer">Guru</a>
        <a href={site.links.email}>Email</a>
      </div>
    </div>
  </footer>
</BaseLayout>

<script>
  const header = document.getElementById("site-header");
  if (header) {
    const onScroll = () => {
      header.classList.toggle("is-scrolled", window.scrollY > 12);
    };
    onScroll();
    window.addEventListener("scroll", onScroll, { passive: true });
  }
</script>
